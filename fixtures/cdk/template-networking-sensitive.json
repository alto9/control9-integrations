{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "ExampleVpc": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16"
      }
    },
    "ExampleSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Example security group",
        "VpcId": { "Ref": "ExampleVpc" }
      }
    }
  }
}
