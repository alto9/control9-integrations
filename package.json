{
  "name": "control9-github-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that builds redacted, signed Control9 action envelopes from IaC artifacts",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:github && npm run build:gitlab",
    "build:github": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:gitlab": "ncc build src/gitlab/index.ts -o dist/gitlab --source-map --license licenses.txt",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package:release": "npm run build && bash scripts/package-release-bundle.sh",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.1.4"
  }
}
